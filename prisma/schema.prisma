// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Result {
  CORRECT
  INCORRECT
  PARTIAL
}

model Decks {
  id     String @id @default(uuid())
  userId String 
  name   String
  card   Cards[]
}

model Cards {
  id           String @id @default(uuid())
  deckId       String 
  deck         Decks  @relation(fields: [deckId], references: [id])

  front        String
  back         String
  answerAt     DateTime @default(now())
  intervalDays Int @default(0)

  record       Records[]
}

model Records {
  id          String @id @default(uuid())
  cardId      String
  card        Cards @relation(fields: [cardId], references: [id])
  userId      String
  result      Result
}
