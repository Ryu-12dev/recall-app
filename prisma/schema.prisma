// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Result {
  CORRECT
  INCORRECT
  PARTIAL
}

model Decks {
  id     String @id 
  userId String 
  name   String
}

model Cards {
  id     String @id 
  deckId String 
  front  String
  back   String
  answerAt DateTime @default(now())
}

model Records {
  id          String @id
  cardId      String
  userId      String
  result      Result
}
